# Nexus v2 — Environment Variables
# Copy to .env and fill in your credentials

# Database
NEXUS_DB_PASSWORD=nexus_dev

# Binance API (Futures)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

# Bybit API
BYBIT_API_KEY=your_bybit_api_key
BYBIT_SECRET=your_bybit_secret

# Collector mode: binance | bybit
COLLECTOR_MODE=binance

# Universe file (list of symbols, one per line)
UNIVERSE_FILE=universe.txt

# Telegram (for bots)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# 9Router (for adversarial v2)
NINE_ROUTER_API_KEY=your_9router_api_key
NINE_ROUTER_BASE=http://host.docker.internal:20128/v1
ADVERSARIAL_MODEL=gc/gemini-2.5-pro
ADVERSARIAL_MODEL_FALLBACK=gc/gemini-2.5-pro
ADVERSARIAL_VERSION=v2

# ============================================================
# Signal Copy Pipeline — Telegram signal listener + execution
# ============================================================

# Telegram source (Telethon user-account backend - reads ANY joined group)
SIGNAL_COPY_TG_API_ID=your_telegram_api_id
SIGNAL_COPY_TG_API_HASH=your_telegram_api_hash
SIGNAL_COPY_TG_SESSION=signal_copy_session

# OR Telegram source (aiogram bot backend - only chats where bot is admin)
# SIGNAL_COPY_TG_LISTENER_BOT_TOKEN=your_listener_bot_token

# Channels to read signals from (comma-separated chat IDs, empty = all joined)
SIGNAL_COPY_TG_CHANNELS=-1001234567890,-1009876543210

# --- Separate notification channels (3 different bots) ---
# 1. Parser/Validation channel (VALID/WEAK/REJECT reports)
SIGNAL_COPY_PARSER_NOTIFY_BOT_TOKEN=your_parser_notify_bot_token
SIGNAL_COPY_PARSER_NOTIFY_CHAT_ID=-1001111111111

# 2. Trades/Execution channel (entry, TP, SL, close)
SIGNAL_COPY_TRADES_NOTIFY_BOT_TOKEN=your_trades_notify_bot_token
SIGNAL_COPY_TRADES_NOTIFY_CHAT_ID=-1002222222222

# 3. Confirmation bot (interactive yes/no for execution)
SIGNAL_COPY_CONFIRM_BOT_TOKEN=your_confirm_bot_token
SIGNAL_COPY_CONFIRM_CHAT_ID=123456789

# Legacy fallback (if individual tokens not set)
SIGNAL_COPY_NOTIFY_BOT_TOKEN=

# Behavior
SIGNAL_COPY_RISK_PCT=0.01
SIGNAL_COPY_DRY_RUN=true
SIGNAL_COPY_AUTO_EXECUTE=false
SIGNAL_COPY_ADVERSARIAL_ENABLED=true
SIGNAL_COPY_PARSE_REPORT=false
SIGNAL_COPY_NOTIFY_REJECTED=true
SIGNAL_COPY_NOTIFY_WEAK=true
# Legacy validation mode (permissive - mirrors old bot behavior)
SIGNAL_COPY_LEGACY_VALIDATION=true

# Discord (optional)
SIGNAL_COPY_DISCORD_ENABLED=false
SIGNAL_COPY_DISCORD_BOT_TOKEN=
SIGNAL_COPY_DISCORD_CHANNELS=

# Vision (optional - for chart image reading)
SIGNAL_COPY_VISION_ENABLED=false
SIGNAL_COPY_OLLAMA_URL=http://host.docker.internal:11434
SIGNAL_COPY_VISION_MODEL=qwen2.5vl:3b